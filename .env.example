# Accountless local mode. The supported container configuration is
# install/.env.ce.example; these values also document direct-process defaults.
DEPLOYMENT_MODE=offline
API_HOST=127.0.0.1
API_PORT=9000
HEADLESS=1

# Local storage and backend URL. Keep both paths on operator-controlled media.
FLYTO_OFFLINE_DB_PATH=./data/offline.db
FLYTO_BACKEND_URL=http://127.0.0.1:9000

# Optional. Leave empty on loopback. Set a long random value only when an
# authenticated reverse proxy deliberately exposes the MCP endpoint.
FLYTO_FLOW_MCP_TOKEN=

FLYTO_EXECUTION_DB_PATH=./data/executions.db
QUEUE_BACKEND=sqlite
FLYTO_QUEUE_FACTORY=
FLYTO_CONNECTION_RUNTIME_FACTORY=
FLYTO_PROVIDER_BUNDLE=
FLYTO_PROVIDER_MODULE_ALLOWLIST=flyto2_enterprise_extensions
FLYTO_USE_QUEUE=false
FLYTO_WORKER_POOL_SIZE=4

# Required before storing credentials outside DEBUG mode.
FLYTO_KEY_BACKEND=local
FLYTO_KEY_BACKEND_FACTORY=
FLYTO_ENCRYPTION_KEY=
FLYTO_KEY_SALT=
FLYTO_ENCRYPTION_KEY_VERSION=1
FLYTO_ENCRYPTION_PREVIOUS_KEYS=

# Vault Transit and AWS KMS are optional remote alternatives. Prefer a
# mounted Vault Agent token file or workload IAM over static credentials.
VAULT_ADDR=
VAULT_TOKEN_FILE=
VAULT_CACERT=
VAULT_NAMESPACE=
VAULT_TRANSIT_MOUNT_POINT=transit
VAULT_TRANSIT_KEY=flyto-credentials
AWS_KMS_KEY_ID=
AWS_REGION=us-east-1
FLYTO_KMS_ALLOW_LEGACY_CIPHERTEXT=false

# Optional signed extension directory. Permission grants map extension IDs to
# the maximum capabilities the local operator approves.
FLYTO_EXTENSIONS_DIR=./data/extensions
FLYTO_EXTENSION_SIGNATURE_POLICY=require-signature
FLYTO_EXTENSION_TRUSTED_KEYS=
FLYTO_EXTENSION_REVOKED_KEYS=
FLYTO_EXTENSION_PERMISSION_GRANTS=
FLYTO_EXTENSION_MAX_ARTIFACT_BYTES=536870912

# Optional alert delivery. The webhook must use HTTPS and its host must be
# explicitly allowlisted.
FLYTO_ALERT_WEBHOOK_URL=
FLYTO_ALERT_WEBHOOK_ALLOWED_HOSTS=
FLYTO_TRACE_EXPORTER_FACTORY=
FLYTO_ALERT_WEBHOOK_SECRET=

FLYTO_BACKUP_MAX_BYTES=10737418240
