# Accountless local mode. The supported container configuration is
# install/.env.ce.example; these values also document direct-process defaults.
DEPLOYMENT_MODE=offline
API_HOST=127.0.0.1
API_PORT=9000
HEADLESS=1

# Local storage and backend URL. Keep both paths on operator-controlled media.
FLYTO_OFFLINE_DB_PATH=./data/offline.db
FLYTO_BACKEND_URL=http://127.0.0.1:9000

# Optional. Leave empty on loopback. Set a long random value only when an
# authenticated reverse proxy deliberately exposes the MCP endpoint.
FLYTO_FLOW_MCP_TOKEN=
