{
  "schema": "flyto.flow-cloud-sync.v2",
  "flow_repository": "flytohub/flyto-flow",
  "cloud_repository": "flytohub/flyto-cloud",
  "mode": "guarded-bidirectional-pull-request",
  "canonical_baseline": "flytohub/flyto-flow",
  "cloud_backports": "allowlisted-shared-files-only",
  "contract": {
    "version": 2,
    "manifest_policy": "byte-identical",
    "source_ref_policy": "immutable-commit-sha",
    "target_ref_policy": "immutable-commit-sha",
    "path_policy": "exact-file-allowlist",
    "candidate_diff_policy": "exact-selected-paths",
    "change_unit": "pull-request",
    "conflict_policy": "fail-closed",
    "provenance_fields": [
      "source_repository",
      "source_sha",
      "source_manifest_sha256",
      "target_repository",
      "target_sha",
      "contract_version"
    ]
  },
