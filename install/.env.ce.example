# Copy this file to install/.env.ce. Flyto2 Flow has no identity service and
# the default Compose port remains bound to loopback.
DEPLOYMENT_MODE=offline
API_HOST=0.0.0.0
API_PORT=9000
HEADLESS=1

FLYTO_OFFLINE_DB_PATH=/data/flyto/offline.db
FLYTO_EXECUTION_DB_PATH=/data/flyto/executions.db
FLYTO_BACKEND_URL=http://127.0.0.1:9000

# Trust Docker's private bridge only when the published host port remains
# bound to 127.0.0.1 as defined by docker-compose.ce.yml.
FLYTO_FLOW_MCP_TRUST_LOOPBACK_PROXY=1

# Optional. Leave empty for accountless loopback MCP. Set a long random value
# only when deliberately exposing MCP through your own reverse proxy.
FLYTO_FLOW_MCP_TOKEN=

# Optional local queue workers. Keep SQLite for one appliance. A private
# Enterprise distribution can inject an allowlisted shared QueueInterface.
QUEUE_BACKEND=sqlite
FLYTO_QUEUE_FACTORY=
FLYTO_CONNECTION_RUNTIME_FACTORY=
FLYTO_PROVIDER_BUNDLE=
FLYTO_PROVIDER_MODULE_ALLOWLIST=flyto2_enterprise_extensions
FLYTO_USE_QUEUE=false
FLYTO_WORKER_POOL_SIZE=4

# Credential encryption. Production operators must set a unique key and salt
# when storing credentials, or select a packaged Vault/KMS adapter.
FLYTO_KEY_BACKEND=local
FLYTO_KEY_BACKEND_FACTORY=
FLYTO_ENCRYPTION_KEY=
FLYTO_KEY_SALT=
FLYTO_ENCRYPTION_KEY_VERSION=1
FLYTO_ENCRYPTION_PREVIOUS_KEYS=

# Vault Transit alternative:
# FLYTO_KEY_BACKEND=vault
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN_FILE=/run/secrets/vault-token
# VAULT_CACERT=/run/secrets/vault-ca.pem
# VAULT_NAMESPACE=
# VAULT_TRANSIT_MOUNT_POINT=transit
# VAULT_TRANSIT_KEY=flyto-credentials

# AWS KMS alternative. Use the container's ambient IAM role or workload
# identity instead of static AWS credentials.
# FLYTO_KEY_BACKEND=kms
# AWS_KMS_KEY_ID=arn:aws:kms:region:account:key/key-id
# AWS_REGION=us-east-1
# FLYTO_KMS_ALLOW_LEGACY_CIPHERTEXT=false

# Production extension bundles require Ed25519 signatures.
FLYTO_EXTENSIONS_DIR=/data/flyto/extensions
FLYTO_EXTENSION_SIGNATURE_POLICY=require-signature
FLYTO_EXTENSION_TRUSTED_KEYS=
FLYTO_EXTENSION_REVOKED_KEYS=
FLYTO_EXTENSION_PERMISSION_GRANTS=
FLYTO_EXTENSION_MAX_ARTIFACT_BYTES=536870912

# Optional HTTPS alert webhook.
FLYTO_ALERT_WEBHOOK_URL=
FLYTO_ALERT_WEBHOOK_ALLOWED_HOSTS=
FLYTO_TRACE_EXPORTER_FACTORY=
FLYTO_ALERT_WEBHOOK_SECRET=

FLYTO_BACKUP_MAX_BYTES=10737418240
