FROM --platform=$BUILDPLATFORM node:20-bookworm-slim@sha256:2cf067cfed83d5ea958367df9f966191a942351a2df77d6f0193e162b5febfc0 AS frontend

WORKDIR /frontend
COPY src/ui/web/frontend/package*.json ./
RUN npm ci
COPY src/ui/web/frontend/ ./
RUN npm run check:i18n-static && npm run build

FROM python:3.12-slim@sha256:57cd7c3a7a273101a6485ba99423ee568157882804b1124b4dd04266317710de AS backend

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DEPLOYMENT_MODE=offline \
    FLYTO_OFFLINE_DB_PATH=/data/flyto/offline.db \
    FLYTO_CORE_UPDATE_DIR=/data/flyto/core \
    API_HOST=0.0.0.0 \
    API_PORT=9000 \
    HEADLESS=1 \
    PLAYWRIGHT_BROWSERS_PATH=/opt/ms-playwright \
    FLYTO_REQUIRE_BUNDLED_RUNTIME=1 \
    FLYTO_VERSION_FILE=/app/VERSION \
    HOME=/home/appuser

WORKDIR /app/backend

COPY VERSION /app/VERSION
COPY src/ui/web/backend/requirements-ce.lock requirements.txt
COPY install/check-bundled-browser.py /tmp/check-bundled-browser.py
RUN python -m pip install --no-cache-dir --upgrade "pip==26.1.2" \
    && python -m pip install --no-cache-dir --require-hashes -r requirements.txt

# Browser automation is part of the CE appliance, not a first-run download.
# /data is a runtime volume, so browsers must live in the immutable image.
RUN python -m pip install --no-cache-dir --only-binary=:all: "playwright==1.57.0" \
    && python -m playwright install --with-deps chromium \
    && python -c "from importlib.metadata import version; assert version('flyto-core') == '2.26.9'" \
    && python /tmp/check-bundled-browser.py

COPY src/ui/web/backend/ /app/backend/
COPY --from=frontend /frontend/dist /app/static

RUN adduser --disabled-password --gecos "" appuser \
    && mkdir -p /data/flyto \
    && chown -R appuser:appuser /data /app /home/appuser

USER appuser
EXPOSE 9000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:9000/api/health')" || exit 1

CMD ["python", "main_offline.py", "--host", "0.0.0.0", "--port", "9000", "--no-reload"]
