{
  "name": "flyto2-flow-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "build:obfuscate": "ENABLE_OBFUSCATION=1 NODE_ENV=production vite build --mode production",
    "preview": "vite preview",
    "analyze": "npx vite-bundle-visualizer",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:i18n-static": "node scripts/check-static-i18n.mjs",
    "validate:size": "node scripts/validateComponentSize.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit:security": "npm audit --audit-level=high",
    "release:bundle-budget": "node scripts/check-release-bundle-budget.mjs",
    "release:static-smoke": "node scripts/release-static-smoke.mjs",
    "release:browser-smoke": "node scripts/release-browser-smoke.mjs"
  },
  "dependencies": {
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/core": "^1.48.0",
    "@vue-flow/minimap": "^1.5.4",
    "axios": "^1.16.0",
    "chart.js": "^4.5.1",
    "circle-flags": "^2.8.2",
    "dompurify": "^3.4.10",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.2.0",
    "lucide-vue-next": "^0.555.0",
    "marked": "^17.0.1",
    "monaco-editor": "^0.53.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@unocss/reset": "^66.5.9",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.0.11",
    "javascript-obfuscator": "^4.1.1",
    "jsdom": "^27.0.1",
    "playwright": "^1.57.0",
    "rollup-plugin-obfuscator": "^1.1.0",
    "terser": "^5.31.0",
    "unocss": "^66.5.9",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
