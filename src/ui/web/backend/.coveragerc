[run]
source =
    api/agent
    api/engine
    api/browser
    api/breakpoint
    api/core
    api/telemetry
    api/workflows
    api/executions
    api/triggers
omit =
    tests/*
    */test_*
    */__pycache__/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__
    raise NotImplementedError
    pass
    except ImportError
show_missing = true
precision = 2
fail_under = 60

[html]
directory = htmlcov
